def main():
    if len(sys.argv) < 2:
        console.print(Panel(
            "[bold cyan]Exception Checker[/bold cyan]\n\n"
            "[bold]Usage:[/bold] python3 exception_checker.py <script.py>\n\n"
            "Analyzes a Python script for uncaught exceptions by:\n"
            "  • Parsing the AST of the target and all local imports\n"
            "  • Discovering custom exception classes and their hierarchies\n"
            "  • Dynamically inferring which exceptions each call can raise\n"
            "  • Checking if try/except blocks catch all possible exceptions\n"
            "  • Tracing through the full call stack\n\n"
            "[dim]Auto-bootstraps dependencies via uv if needed.[/dim]",
            box=box.DOUBLE,
            border_style="cyan",
        ))
        sys.exit(1)

    target_file = sys.argv[1]

    if not os.path.exists(target_file):
        console.print(f"[red bold]Error:[/] File '{target_file}' does not exist.")
        sys.exit(1)

    if not target_file.endswith('.py'):
        console.print(f"[yellow]Warning:[/] '{target_file}' does not have a .py extension. Proceeding anyway.")

    analyzer = ScriptAnalyzer()
    analyzer.analyze(target_file)


if __name__ == "__main__":
    main()
