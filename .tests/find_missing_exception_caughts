#!/usr/bin/env python3
"""
Exception Checker - Analyzes Python scripts for uncaught exceptions.
Auto-bootstraps via uv if needed.
"""

import sys
import os
import subprocess
import shutil

# === AUTO-BOOTSTRAP VIA UV ===
REQUIRED_PACKAGES = ["rich"]
SCRIPT_NAME = os.path.basename(__file__)


def _check_uv_available():
    """Check if uv is available on PATH."""
    return shutil.which("uv") is not None


def _is_running_in_uv():
    """Detect if we're already running inside a uv-bootstrapped environment."""
    return os.environ.get("_EXCEPTION_CHECKER_UV_BOOTSTRAPPED") == "1"


def _bootstrap_via_uv():
    """Restart this script via uv with all dependencies."""
    if not _check_uv_available():
        print(
            "\033[91mError: 'uv' is not installed.\033[0m",
            file=sys.stderr,
        )
        print(
            "Install uv: curl -LsSf https://astral.sh/uv/install.sh | sh",
            file=sys.stderr,
        )
        sys.exit(1)

    env = os.environ.copy()
    env["_EXCEPTION_CHECKER_UV_BOOTSTRAPPED"] = "1"

    cmd = ["uv", "run", "--with", ",".join(REQUIRED_PACKAGES), "python3", __file__] + sys.argv[1:]

    try:
        result = subprocess.run(cmd, env=env)
        sys.exit(result.returncode)
    except FileNotFoundError:
        print("\033[91mError: Could not execute uv.\033[0m", file=sys.stderr)
        sys.exit(1)


def _check_dependencies():
    """Check if all dependencies are importable."""
    try:
        import rich  # noqa: F401
        return True
    except ImportError:
        return False


# Bootstrap logic: if deps missing, restart via uv
if not _is_running_in_uv() and not _check_dependencies():
    _bootstrap_via_uv()

