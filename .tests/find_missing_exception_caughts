                f"[yellow]{ue.exception_type}[/yellow] is uncaught"
            )
            tree.add(f"[dim]File:[/dim] {os.path.relpath(ue.file_path)}")
            tree.add(f"[dim]Code:[/dim] [cyan]{escape(ue.context)}[/cyan]")
            tree.add(f"[dim]Reason:[/dim] {ue.reason}")

            if ue.source_chain:
                chain_parts = [str(s) for s in ue.source_chain if s]
                if chain_parts:
                    chain = " → ".join(chain_parts)
                    tree.add(f"[dim]Source:[/dim] {chain}")

            suggestion = self._generate_fix_suggestion(ue)
            tree.add(f"[green]Suggested fix:[/green] {suggestion}")

            console.print(tree)
            console.print()

        if len(unique_uncaught) > max_details:
            console.print(f"[dim]... and {len(unique_uncaught) - max_details} more.[/dim]")

        # Statistics
        console.print()
        stats_table = Table(title="Statistics", box=box.ROUNDED, border_style="blue")
        stats_table.add_column("Metric", style="bold")
        stats_table.add_column("Value", style="cyan")

        exc_types = set(ue.exception_type for ue in unique_uncaught)
        stats_table.add_row("Total uncaught exceptions", str(len(unique_uncaught)))
        stats_table.add_row("Distinct exception types", str(len(exc_types)))
        stats_table.add_row("Affected files", str(len(by_file)))
        stats_table.add_row("Files analyzed", str(len(self._parsed_trees)))
        stats_table.add_row("Custom exceptions found", str(len(self.registry._custom_exceptions)))
        stats_table.add_row("Functions analyzed", str(len(self.function_defs)))

        console.print(stats_table)

        # Top exception types
        console.print()
        exc_counter = Counter(ue.exception_type for ue in unique_uncaught)
        top_table = Table(title="Most Common Uncaught Exceptions", box=box.ROUNDED, border_style="yellow")
        top_table.add_column("Exception", style="red bold")
        top_table.add_column("Count", style="cyan", justify="right")
        top_table.add_column("Hierarchy", style="dim")

        for exc_name, count in exc_counter.most_common(15):
            hierarchy = self._get_exception_hierarchy_str(exc_name)
            top_table.add_row(exc_name, str(count), hierarchy)

        console.print(top_table)

    def _get_exception_hierarchy_str(self, exc_name: str) -> str:
        """Get a string representation of the exception's class hierarchy."""
        if exc_name in self.registry._builtin_exceptions:
            cls = self.registry._builtin_exceptions[exc_name]
            mro = [c.__name__ for c in cls.__mro__ if c.__name__ not in ('object',)]
            return " < ".join(mro)
        elif exc_name in self.registry._custom_exceptions:
            bases = self.registry._custom_exceptions[exc_name]
            return f"{exc_name} < {' < '.join(bases)}"
        return exc_name

    def _generate_fix_suggestion(self, ue: UncaughtException) -> str:
        """Generate a fix suggestion for an uncaught exception."""
        exc = ue.exception_type

        # Dynamically based on exception hierarchy
        if exc in self.registry._builtin_exceptions:
            exc_class = self.registry._builtin_exceptions[exc]
            mro = exc_class.__mro__
            # Find the nearest meaningful parent
            parents = []
            for parent in mro[1:]:
                if parent.__name__ in ('Exception', 'BaseException', 'object'):
                    break
                parents.append(parent.__name__)

            if parents:
                return (
                    f"Wrap in try/except {exc}, or catch more broadly with "
                    f"except {parents[0]}"
                )

        if exc in self.registry._custom_exceptions:
            bases = self.registry._custom_exceptions[exc]
            if bases:
                return f"Wrap in try/except {exc} or except {bases[0]}"

        return f"Add 'except {exc}' to the try block, or handle the error case"


